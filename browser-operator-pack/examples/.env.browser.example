# Copy the relevant values into ~/.hermes/.env
# Restart gateway or start a new CLI session after editing.

CAMOFOX_URL=http://127.0.0.1:9377

# Optional launch defaults for scripts/install-camofox-browser.sh
CAMOFOX_WORKDIR=$HOME/camofox-browser
CAMOFOX_PORT=9377
CAMOFOX_DISPLAY=:99
CAMOFOX_DEFAULT_TIMEZONE=Europe/Moscow
CAMOFOX_DEFAULT_LAT=55.7558
CAMOFOX_DEFAULT_LON=37.6173
CAMOFOX_DEFAULT_LOCALE=ru-RU
